{
  "entities": {
    "User": {
      "title": "User",
      "description": "Authenticated user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatLog": {
      "title": "ChatLog",
      "description": "Logs of user interactions with the AI chatbot",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["query", "response", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/chat_logs/{logId}": {
      "schema": "ChatLog",
      "description": "AI chatbot interaction logs"
    }
  }
}
